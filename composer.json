{
    "name": "truelist/truelist-php",
    "description": "PHP SDK for the Truelist email validation API",
    "type": "library",
    "license": "MIT",
    "keywords": ["email", "validation", "truelist", "email-verification"],
    "homepage": "https://truelist.io",
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Truelist\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Truelist\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
